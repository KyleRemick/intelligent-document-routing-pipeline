# Copy to samconfig.toml (gitignored) after `sam deploy --guided`, or adjust and use:
#   sam deploy --config-env default

version = 0.1

[default]
[default.global.parameters]
stack_name = "doc-routing-pipeline"

[default.build.parameters]
cached = true
parallel = true

[default.deploy.parameters]
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3 = true
region = "us-east-1"
